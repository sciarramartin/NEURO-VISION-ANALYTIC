{
  "name": "parkinson-analytic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"const { spawn } = require('child_process'); spawn('npx', ['@tailwindcss/cli', '-i', './src/app/globals.css', '-o', './src/app/globals.compiled.css', '--watch'], { stdio: 'inherit', shell: true }); spawn('next', ['dev'], { stdio: 'inherit', shell: true });\"",
    "build": "npx @tailwindcss/cli -i ./src/app/globals.css -o ./src/app/globals.compiled.css && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@supabase/supabase-js": "^2.108.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "puppeteer-core": "^25.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
